    {
      "name": "12. Custom Endpoint",
      "description": "custom actuator endpoint 확인.",
      "item": [
        {
          "name": "Set Dark Mode Feature",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"enabled\": true}"
            },
            "url": "{{actuatorUrl}}/actuator/features/dark-mode"
          }
        },
        {
          "name": "Feature Toggles",
          "request": {
            "method": "GET",
            "url": "{{actuatorUrl}}/actuator/features"
          }
        },
        {
          "name": "Dark Mode Feature",
          "request": {
            "method": "GET",
            "url": "{{actuatorUrl}}/actuator/features/dark-mode"
          }
        },
        {
          "name": "Remove Dark Mode Feature",
          "request": {
            "method": "DELETE",
            "url": "{{actuatorUrl}}/actuator/features/dark-mode"
          }
        }
